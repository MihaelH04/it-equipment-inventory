<style>
    .autocomplete-wrapper {
        position: relative;
    }

    .autocomplete-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1050;
        background: #fff;
        border: 1px solid #ced4da;
        border-top: none;
        border-radius: 0 0 0.375rem 0.375rem;
        max-height: 240px;
        overflow-y: auto;
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.08);
        display: none;
    }

    .autocomplete-item {
        padding: 10px 12px;
        cursor: pointer;
        border-bottom: 1px solid #f1f1f1;
    }

    .autocomplete-item:hover,
    .autocomplete-item.active {
        background-color: #f8f9fa;
    }

    .autocomplete-empty {
        padding: 10px 12px;
        color: #6c757d;
    }

    .autocomplete-highlight {
        font-weight: 700;
        color: #0d6efd;
    }
</style>

<script>
    function escapeHtml(text) {
        return text
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function highlightMatch(text, term) {
        if (!term) return escapeHtml(text);

        const lowerText = text.toLowerCase();
        const lowerTerm = term.toLowerCase();
        const index = lowerText.indexOf(lowerTerm);

        if (index === -1) return escapeHtml(text);

        const before = escapeHtml(text.substring(0, index));
        const match = escapeHtml(text.substring(index, index + term.length));
        const after = escapeHtml(text.substring(index + term.length));

        return `${before}<span class="autocomplete-highlight">${match}</span>${after}`;
    }

    function setupSearchableInput(inputId, hiddenId, items) {
        const input = document.getElementById(inputId);
        const hidden = document.getElementById(hiddenId);

        if (!input || !hidden) return;

        input.removeAttribute("list");

        let wrapper = input.parentElement;
        if (!wrapper.classList.contains("autocomplete-wrapper")) {
            const newWrapper = document.createElement("div");
            newWrapper.className = "autocomplete-wrapper";
            input.parentNode.insertBefore(newWrapper, input);
            newWrapper.appendChild(input);
            wrapper = newWrapper;
        }

        let dropdown = wrapper.querySelector(".autocomplete-list");
        if (!dropdown) {
            dropdown = document.createElement("div");
            dropdown.className = "autocomplete-list";
            wrapper.appendChild(dropdown);
        }

        let currentIndex = -1;
        let filteredItems = [];

        function closeDropdown() {
            dropdown.style.display = "none";
            dropdown.innerHTML = "";
            currentIndex = -1;
        }

        function openDropdown() {
            if (dropdown.innerHTML.trim() !== "") {
                dropdown.style.display = "block";
            }
        }

        function renderDropdown(term) {
            const normalized = (term || "").trim().toLowerCase();

            filteredItems = normalized.length === 0
                ? items.slice(0, 15)
                : items.filter(x => x.text.toLowerCase().includes(normalized)).slice(0, 20);

            dropdown.innerHTML = "";

            if (filteredItems.length === 0) {
                dropdown.innerHTML = `<div class="autocomplete-empty">Nema rezultata</div>`;
                dropdown.style.display = "block";
                return;
            }

            filteredItems.forEach((item, index) => {
                const div = document.createElement("div");
                div.className = "autocomplete-item";
                div.dataset.index = index;
                div.dataset.id = item.id;
                div.dataset.text = item.text;
                div.innerHTML = highlightMatch(item.text, term);

                div.addEventListener("mousedown", function (e) {
                    e.preventDefault();
                    input.value = item.text;
                    hidden.value = item.id;
                    closeDropdown();
                });

                dropdown.appendChild(div);
            });

            openDropdown();
        }

        function syncHiddenExact() {
            const typed = input.value.trim().toLowerCase();
            const exactMatch = items.find(x => x.text.toLowerCase() === typed);
            hidden.value = exactMatch ? exactMatch.id : "";
        }

        function setActiveItem() {
            const optionElements = dropdown.querySelectorAll(".autocomplete-item");
            optionElements.forEach(el => el.classList.remove("active"));

            if (currentIndex >= 0 && currentIndex < optionElements.length) {
                optionElements[currentIndex].classList.add("active");
                optionElements[currentIndex].scrollIntoView({ block: "nearest" });
            }
        }

        input.addEventListener("focus", function () {
            renderDropdown(input.value);
        });

        input.addEventListener("input", function () {
            syncHiddenExact();
            renderDropdown(input.value);
        });

        input.addEventListener("keydown", function (e) {
            const optionElements = dropdown.querySelectorAll(".autocomplete-item");

            if (dropdown.style.display === "block") {
                if (e.key === "ArrowDown") {
                    e.preventDefault();
                    currentIndex = Math.min(currentIndex + 1, optionElements.length - 1);
                    setActiveItem();
                }
                else if (e.key === "ArrowUp") {
                    e.preventDefault();
                    currentIndex = Math.max(currentIndex - 1, 0);
                    setActiveItem();
                }
                else if (e.key === "Enter") {
                    if (currentIndex >= 0 && currentIndex < optionElements.length) {
                        e.preventDefault();
                        optionElements[currentIndex].dispatchEvent(new Event("mousedown"));
                    }
                }
                else if (e.key === "Escape") {
                    closeDropdown();
                }
            }
        });

        input.addEventListener("blur", function () {
            setTimeout(() => {
                syncHiddenExact();
                closeDropdown();
            }, 150);
        });
    }
</script>