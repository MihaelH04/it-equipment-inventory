@model IEnumerable<ITEquipmentInventory.Models.Site>

@{
    ViewData["Title"] = "Potvrda brisanja odabranih radnih naloga";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="fw-bold mb-2">Potvrda brisanja odabranih radnih naloga</h1>
        <p class="text-muted mb-0">
            Provjeri popis radnih naloga prije trajnog brisanja.
        </p>
    </div>

    <div class="alert alert-warning rounded-4 border-0 shadow-sm">
        <strong>Pažnja:</strong> Obrisat će se ukupno <strong>@Model.Count()</strong> radnih naloga.
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Naziv</th>
                            <th>Šifra</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var site in Model)
                        {
                            <tr>
                                <td>@site.Name</td>
                                <td>@(string.IsNullOrWhiteSpace(site.Code) ? "-" : site.Code)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <form asp-action="DeleteSelectedConfirmed" method="post">
        @Html.AntiForgeryToken()

        @foreach (var site in Model)
        {
            <input type="hidden" name="selectedIds" value="@site.Id" />
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger rounded-4 px-4">
                Da, obriši odabrane radne naloge
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-4 px-4">
                Odustani
            </a>
        </div>
    </form>
</div>