@model IEnumerable<ITEquipmentInventory.Models.Equipment>

@{
    ViewData["Title"] = "Potvrda brisanja odabrane opreme";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="fw-bold mb-2">Potvrda brisanja odabrane opreme</h1>
        <p class="text-muted mb-0">
            Provjeri odabrane stavke prije trajnog brisanja.
        </p>
    </div>

    <div class="alert alert-warning rounded-4 border-0 shadow-sm">
        <strong>Pažnja:</strong> Obrisat će se ukupno <strong>@Model.Count()</strong> stavki opreme.
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Inventurni broj</th>
                            <th>Naziv</th>
                            <th>Vrsta</th>
                            <th>Status</th>
                            <th>Radni nalog</th>
                            <th>Zaposlenik</th>
                            <th>Predao</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.InventoryNumber</td>
                                <td>@item.Name</td>
                                <td>@item.EquipmentType</td>
                                <td>@item.Status</td>
                                <td>@(item.CurrentSite?.Name ?? "-")</td>
                                <td>@(item.CurrentEmployee?.FullName ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(item.HandedOverBy) ? "-" : item.HandedOverBy)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <form asp-action="DeleteSelectedConfirmed" method="post">
        @Html.AntiForgeryToken()

        @foreach (var item in Model)
        {
            <input type="hidden" name="selectedIds" value="@item.Id" />
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger rounded-4 px-4">
                Da, obriši odabrano
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary rounded-4 px-4">
                Odustani
            </a>
        </div>
    </form>
</div>